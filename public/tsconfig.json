{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "lib": ["ES2016", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./scripts/*"],
      "@/lib": ["./scripts/index"]
    }
  },
  "include": ["scripts/**/*", "../src/types/shared.ts"]
}
